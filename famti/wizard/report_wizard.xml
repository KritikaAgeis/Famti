<odoo>
    <record id="view_sale_report_wizard" model="ir.ui.view">
        <field name="name">sale.report.wizard.form</field>
        <field name="model">sale.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Sales Report">
                <group>
                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                    <group>
                        <field name="partner_id"/>
                    </group>                    
                </group>
                <footer>
                    <button name="action_generate_excel"
                            type="object"
                            string="Export Excel"
                            class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_daily_inventory_report_wizard" model="ir.ui.view">
        <field name="name">daily.inventory.report.wizard.form</field>
        <field name="model">daily.inventory.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Daily Inventory Report">

                <group>
                    <field name="from_date"/>
                    <field name="to_date"/>
                </group>

                <footer>
                    <button name="action_print_report"
                            type="object"
                            string="Print Report"
                            class="btn-primary"/>

                    <button string="Cancel"
                            special="cancel"/>

                </footer>

            </form>
        </field>
    </record>

    <record id="action_daily_inventory_report_wizard" model="ir.actions.act_window">
        <field name="name">Daily Inventory Report</field>
        <field name="res_model">daily.inventory.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_daily_inventory_report"
        name="Daily Inventory Report"
        parent="stock.menu_warehouse_report"
        action="action_daily_inventory_report_wizard"
        sequence="50"/>

    <record id="view_mis_monthly_report_wizard_form" model="ir.ui.view">
        <field name="name">mis.monthly.report.wizard.form</field>
        <field name="model">mis.monthly.report.wizard</field>
        <field name="arch" type="xml">
            <form string="MIS Monthly Report">
                <group>
                    <field name="month"/>
                    <field name="year"/>
                    <field name="machine"/>
                </group>

                <footer>
                    <button name="action_mis_report_excel"
                            string="Print Excel"
                            type="object"
                            class="btn-primary"/>

                    <button string="Cancel"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_mis_monthly_report" model="ir.actions.act_window">
        <field name="name">MIS Monthly Report</field>
        <field name="res_model">mis.monthly.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem
        id="menu_mis_monthly_report"
        name="MIS Monthly Report"
        parent="stock.menu_warehouse_report"
        action="action_mis_monthly_report"
        sequence="51" />
    
</odoo>

<odoo>
    <record id="view_scrap_confirm_wizard" model="ir.ui.view">
        <field name="name">scrap.confirm.wizard.form</field>
        <field name="model">scrap.confirm.wizard</field>
        <field name="arch" type="xml">
            <form string="Confirm Scrap">
                <group>
                    <div>
                        <strong>Are you sure you want to scrap this record?</strong>
                    </div>
                </group>
                <footer>
                    <button string="Confirm"
                            type="object"
                            name="action_confirm_scrap"
                            class="btn-primary"/>
                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
<odoo>
    <record id="view_scrap_confirm_wizard" model="ir.ui.view">
        <field name="name">scrap.confirm.wizard.form</field>
        <field name="model">scrap.confirm.wizard</field>
        <field name="arch" type="xml">
            <form string="Confirm Scrap">
                <group>
                    <div>
                        <strong>Are you sure you want to scrap this record?</strong>
                    </div>
                </group>
                <footer>
                    <button string="Confirm"
                            type="object"
                            name="action_confirm_scrap"
                            class="btn-primary"/>
                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_maintenance_track_wizard_form" model="ir.ui.view">
        <field name="name">maintenance.track.wizard.form</field>
        <field name="model">maintenance.track.wizard</field>
        <field name="arch" type="xml">
            <form string="Track Maintenance">
                <div class="oe_title">
                    <h1>
                        <field name="maintenance_id" readonly="1" placeholder="e.g. Screen not working"/>
                    </h1>
                </div>
                <group>
                    <group>
                        <field name="team_id"/>
                        <field name="user_id" invisible="show_responsible"/>
                        <field name="contractor_id" invisible="not show_responsible"/>
                        <label for="expected_duration"/>
                        <div>
                            <field name="expected_duration" widget="float_time" class="oe_inline"/> <span class="ml8">hours</span>
                        </div>
                        <field name="schedule_date"/>
                        <field name="request_date"/>
                        
                    </group>

                    <group> 
                        <field name="priority" widget="priority"/>
                        <field name="phone"/>
                        <field name="email"/>
                        <label for="duration"/>
                        <div>
                            <field name="duration" widget="float_time" class="oe_inline"/> <span class="ml8">hours</span>
                        </div>
                        <field name="start_datetime"/>
                        <field name="end_datetime"/>
                    </group>
                </group>
                <notebook>
                        <page string="Notes">
                            <field name="notes" placeholder="Internal Notes"/>
                        </page>
                </notebook>


                <footer>
                    <button name="action_confirm"
                            string="Confirm"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>

<odoo>
    <record id="view_hr_job_reject_wizard_form" model="ir.ui.view">
        <field name="name">hr.job.reject.wizard.form</field>
        <field name="model">hr.job.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Reject Job">
                <group>
                    <field name="remarks" placeholder="Enter rejection reason..."/>
                </group>
                <footer>
                    <button name="action_confirm_reject"
                            string="Confirm"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_hr_resignation_reject_wizard_form" model="ir.ui.view">
        <field name="name">hr.resignation.reject.wizard.form</field>
        <field name="model">hr.resignation.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Reject Resignation">
                <group>
                    <field name="remarks" placeholder="Enter rejection reason..."/>
                </group>
                <footer>
                    <button name="action_confirm_reject"
                            string="Confirm"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>

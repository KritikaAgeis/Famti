<odoo>
    <data noupdate="0">

        <record id="mail_template_vendor_document_expiry" model="mail.template">
            <field name="name">ISO Certificate Expiry Reminder</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="subject">ISO Certificate Expiry Reminder</field>
            <field name="email_from">${(user.email or 'admin@company.com')}</field>
            <field name="email_to">${object.email}</field>

            <field name="body_html">
                <![CDATA[
                <p>Dear ${object.name},</p>

                <p>
                    Your certificate will expire on
                    <strong>${object.vendor_document_expiry}</strong>.
                </p>

                <p>
                    Please renew and share the updated certificate before the expiry date.
                </p>

                <p>
                    Thank you,<br/>
                    ${user.company_id.name}
                </p>
                ]]>
            </field>
        </record>

        <record id="email_template_offer_letter" model="mail.template">
            <field name="name">Offer Letter Email</field>
            <field name="model_id" ref="hr_recruitment.model_hr_applicant"/>
            <field name="subject">
                Offer Letter for the Position of ${object.job_id.name}
            </field>
            <field name="email_to">${object.email_from}</field>
            <field name="body_html">
                <![CDATA[
                <div style="font-family: Arial, sans-serif; font-size:14px;">
                
                <p>Dear <t t-out="object.partner_name"/>,</p>

                <p>
                Greetings from <strong><t t-out="object.company_id.name"/></strong>.
                </p>

                <p>
                We are pleased to inform you that you have been selected for the position of 
                <strong><t t-out="object.job_id.name"/></strong> with our organization.
                </p>

                <p>
                Please find attached your <strong>Offer Letter</strong>.
                </p>

                <p>
                Kindly review and confirm your acceptance.
                </p>

                <p>
                Best Regards,<br/>
                <strong>HR Department</strong><br/>
                <t t-out="object.company_id.name"/>
                </p>

                </div>
                ]]>
            </field>
        </record>

    </data>
</odoo>

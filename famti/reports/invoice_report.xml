<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="action_report_invoice_custom" model="ir.actions.report">
        <field name="name">Invoice</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">famti.report_invoice_custom</field>
        <field name="report_file">famti.report_invoice_custom</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
    </record>

    <template id="external_layout_standard_invoice">

        <t t-set="o" t-value="o or doc"/>
        <t t-set="company" t-value="o and o.company_id or res_company"/>

        <div t-attf-class="header o_company_#{company.id}_layout">

            <div class="row" style="width:100%; margin:0;">

                <div class="col-6" style="padding:0; vertical-align:top;">

                    <img t-if="company.logo"
                        t-att-src="image_data_uri(company.logo)"
                        style="max-height:80px;"/>

                    <br/><br/>

                    <strong><span t-field="company.name"/></strong><br/>

                    <span t-field="company.partner_id"
                        t-options='{"widget": "contact", "fields": ["address", "phone", "website"], "no_marker": true}'/>

                </div>

                <div class="col-6" style="padding:10px;">

                    <td style="width:50%; vertical-align:top;">

                        <div style="border:1px solid black; border-radius:8px; overflow:hidden;">

                            <div style="text-align:center;font-size:18px; padding:6px; font-weight:bold;">
                                INVOICE
                            </div>

                            <div class="row">
                                <div class="col-6" style="padding:0; border-right:1px solid black; padding:5px;">
                                    <strong>Customer ID</strong><br/>
                                    <span t-field="o.partner_id.name"/>
                                </div>

                                <div class="col-6" style="padding:0; padding:5px;">
                                    <strong>Invoice Date</strong><br/>
                                    <span t-field="o.invoice_date" t-options='{"widget": "date"}'/>
                                </div>
                                
                            </div>

                            <div style="text-align:center; font-size:16px; padding:6px;">
                               <strong>Invoice No: </strong> <span t-field="o.name"/>
                            </div>

                        </div>

                    </td>
                </div>

            </div>

            </div><br/><br/>

            <div t-attf-class="article o_company_#{company.id}_layout" style="margin-top:20px;">
                <t t-out="0"/>
            </div>
            <div t-attf-class="footer o_company_#{company.id}_layout"
                style="font-size:11px; margin-top:20px; width:100%;">

                <div style="border-top:1px solid #999; margin-bottom:10px;"></div>

                <div style="margin-top:15px; font-size:10px; text-align:center; line-height:1.6;">
                    <div>
                        <strong>GST/HST Registration No:</strong> 729664474RT0001
                    </div>

                    <div>
                        If you have any questions about this invoice, please contact
                        <strong>accounts@famti.ca</strong>
                    </div>

                    <div style="margin-top:5px;">
                        <strong>Thank You For Your Business!</strong>
                    </div>
                </div>

                <div style="clear:both;"></div>

                <div style="width:100%; margin-top:8px; font-size:10px; color:#666;">

                    <div style="float:right;">
                        <span class="page"/> / <span class="topage"/>
                    </div>

                </div>

                <div style="clear:both;"></div>

            </div>

    </template>


    <template id="report_invoice_custom">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">

                <t t-call="famti.external_layout_standard_invoice">

                    <div class="page">
                        <div style="height:30px;"></div>
                        <div class="row" style="width:100%; margin-top:25px; margin-bottom:20px;">
                            <div class="col-6">
                                <table style="width:100%; border:1px solid black; margin-bottom:10px;">
                                        <tr>
                                            <td style="background:#3b4e87; color:white; padding:5px;">
                                                <strong>BILL TO:</strong>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="padding:5px; font-size:12px;">

                                                <strong><span t-field="o.partner_id.name"/></strong><br/>

                                                <span t-field="o.partner_id.street"/><br/>
                                                <span t-field="o.partner_id.city"/>
                                                <span t-field="o.partner_id.state_id.name"/><br/>
                                                <span t-field="o.partner_id.country_id.name"/><br/>

                                                <strong>Phone:</strong> <span t-field="o.partner_id.phone"/><br/>
                                                <strong>Email:</strong> <span t-field="o.partner_id.email"/>

                                            </td>
                                        </tr>
                                    </table>
                            </div>
                            <div class="col-6">
                                <table style="width:100%; border:1px solid black;">
                                        <tr>
                                            <td style="background:#3b4e87; color:white; padding:5px;">
                                                <strong>SHIP TO:</strong>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="padding:5px; font-size:12px;">

                                                <strong><span t-field="o.partner_id.name"/></strong><br/>

                                                <span t-field="o.partner_shipping_id.street"/><br/>
                                                <span t-field="o.partner_shipping_id.city"/>
                                                <span t-field="o.partner_shipping_id.state_id.name"/><br/>
                                                <span t-field="o.partner_shipping_id.country_id.name"/><br/>

                                                <strong>Phone:</strong> <span t-field="o.partner_shipping_id.phone"/><br/>
                                                <strong>Email:</strong> <span t-field="o.partner_shipping_id.email"/>

                                            </td>
                                        </tr>
                                    </table>
                            </div>
                        </div>

                        
                        <table style="width:100%; margin-top:20px; text-align:center;">
                            <thead style="background:#3b4e87; color:white;">
                                <tr>
                                    <th style="padding:5px;">SALESPERSON</th>
                                    <th style="padding:5px;">PO NUMBER</th>
                                    <th style="padding:5px;">SHIP DATE</th>
                                    <th style="padding:5px;">SHIP VIA</th>
                                    <th style="padding:5px;">STATUS</th>
                                    <th style="padding:5px;">PAYMENT TERMS</th>
                                    <th style="padding:5px;">DELIVERY TERMS</th>
                                </tr>
                            </thead>

                            <tbody>
                                <tr style="text-aligh:center;">
                                    <td>
                                        <span t-field="o.invoice_user_id.name"/>
                                    </td>
                                    <td>
                                        <span t-field="o.invoice_origin"/>
                                    </td>
                                    <td>
                                        <span t-field="o.invoice_date"/>
                                    </td>
                                    <td>
                                        <span t-field="o.ship_via"/>
                                    </td>
                                    <td>
                                        <span t-field="o.state"/>
                                    </td>
                                    <td>
                                        <span t-field="o.invoice_payment_term_id.name"/>
                                    </td>
                                    <td>
                                        <span t-field="o.invoice_incoterm_id.code"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <table style="width:100%; margin-top:20px; text-align:center;">
                            <t t-set="has_pieces" t-value="any(line.pieces for line in o.invoice_line_ids)"/>
                            <thead style="background:#3b4e87; color:white;">
                                <tr>
                                    <th style="padding:5px;">ITEM NUMBER</th>
                                    <th style="padding:5px;">DESCRIPTION</th>
                                    <th style="padding:5px;">Qty (lb)</th>
                                    <th style="padding:5px;" t-if="not has_pieces">UNIT PRICE (per lb)</th>
                                    <th style="padding:5px;" t-if="has_pieces">NO OF ROLLS</th>
                                    <th style="padding:5px;" t-if="has_pieces">UNIT PRICE (PER ROLL)</th>
                                    <th style="padding:5px;">TOTAL (USD/CAD)</th>
                                </tr>
                            </thead>

                            <tbody>
                                <tr t-foreach="o.invoice_line_ids" t-as="line">
                                    <td style="">
                                        <span t-field="line.name"/>
                                    </td>
                                    <td>
                                        <span t-field="line.product_id.film_description"/>
                                    </td>
                                    <td>
                                        <span t-field="line.quantity"/>
                                    </td>
                                    <td t-if="not has_pieces">
                                        <span t-field="line.price_unit"/>
                                    </td>
                                    <td t-if="has_pieces">
                                        <span  t-field="line.pieces"/>
                                    </td>
                                    <td t-if="has_pieces">
                                        <span t-field="line.price_unit"/>
                                    </td>
                                    <td>
                                        <span t-field="line.price_subtotal"/>
                                    </td>
                                </tr>
                            </tbody>

                        </table>
                        <!-- <div class="row" style="margin-top:20px;text-align:center;">
                            <div class="col-12" style="background:#eee;text-align:center;padding:5px;">
                                <t t-set="total_qty" t-value="sum(line.quantity for line in o.invoice_line_ids)"/>
                                <t t-set="total_pieces" t-value="sum(line.pieces or 0 for line in o.invoice_line_ids)"/>
                                <strong style="background:#eee;text-align:center;">TOTAL QTY <span t-esc="total_qty"/></strong>
                                <t t-if="has_pieces">
                                    <strong>  Total no. of rolls:</strong>
                                    <span t-esc="total_pieces"/>
                                </t>
                            </div>                            
                        </div> -->
                        <div class="row" style="margin-top:20px;">
                            <div class="col-6" style="text-align:left;">
                                <span t-field="o.narration"/>
                            </div>  
                            <div class="col-6" style="text-align:center;">

                                <div style="border-top:2px solid black; padding-top:5px;"></div>

                                <div style="width:100%; overflow:hidden; margin-top:5px;">
                                    <div style="float:left;"><strong>SUBTOTAL</strong></div>
                                    <div style="float:right;">
                                        <span t-field="o.amount_untaxed"/>
                                    </div>
                                </div>

                                <div style="clear:both;"></div>

                                <div style="width:100%; overflow:hidden;">
                                    <div style="float:left;"><strong>TAXABLE</strong></div>
                                    <div style="float:right;">$0.00</div>
                                </div>

                                <div style="clear:both;"></div>

                                <div style="width:100%; overflow:hidden;">
                                    <div style="float:left;"><strong>TAX RATE</strong></div>
                                    <div style="float:right;">
                                        <span t-esc="(o.invoice_line_ids and o.invoice_line_ids[0].tax_ids and o.invoice_line_ids[0].tax_ids[0].amount) or 0"/>%
                                    </div>
                                </div>

                                <div style="clear:both;"></div>

                                <div style="width:100%; overflow:hidden;">
                                    <div style="float:left;"><strong>TAX</strong></div>
                                    <div style="float:right;">
                                        <span t-field="o.amount_tax"/>
                                    </div>
                                </div>

                                <div style="clear:both;"></div>

                                <div style="width:100%; overflow:hidden;">
                                    <div style="float:left;"><strong>S &amp; H</strong></div>
                                    <div style="float:right;">$0.00</div>
                                </div>

                                <div style="clear:both;"></div>

                                <div style="width:100%; overflow:hidden;">
                                    <div style="float:left;"><strong>OTHER</strong></div>
                                    <div style="float:right;">$0.00</div>
                                </div>

                                <div style="clear:both;"></div>

                                <div style="border-top:2px solid black; margin-top:8px;"></div>

                                <div style="width:100%; overflow:hidden; margin-top:5px;">
                                    <div style="float:left;"><strong>TOTAL (USD/CAD)</strong></div>
                                    <div style="float:right;">
                                        <strong>
                                            <span t-field="o.amount_total"/>
                                        </strong>
                                    </div>
                                </div>

                                <div style="clear:both;"></div>

                            </div>                          
                        </div>



                    </div>

                </t>
            </t>
        </t>
    </template>

</odoo>

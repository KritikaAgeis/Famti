<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="action_customer_visit_excel" model="ir.actions.server">
        <field name="name">Customer Visit Report</field>
        <field name="model_id" ref="model_customer_visit"/>
        <field name="binding_model_id" ref="model_customer_visit"/>
        <field name="binding_view_types">form</field>
        <field name="state">code</field>
        <field name="code">action = records.action_print_excel()</field>
    </record>

    <record id="action_customer_history_excel" model="ir.actions.server">
        <field name="name">Customer History Report</field>
        <field name="model_id" ref="model_customer_visit"/>
        <field name="binding_model_id" ref="model_customer_visit"/>
        <field name="binding_view_types">form</field>
        <field name="state">code</field>
        <field name="code">action = records.action_customer_history_excel()</field>
    </record>
</odoo>
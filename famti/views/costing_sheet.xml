        <!-- views/Cost sheet template.xml -->
  <record id="view_cost_sheet_template_form" model="ir.ui.view">
    <field name="name">cost.sheet</field>
    <field name="model">cost.sheet.template</field>
    <field name="arch" type="xml">
      <form string="Cost Sheet Template">
        <sheet>
            <group>
                <group>
              <field name="name" readonly="1"/>
              <field name="title"/>
              <field name="code" readonly="1"/>
              <field name="sequence"/>
          </group>
            <group>
              <field name="cost_sheet_id"/>
                  <field name="default_value"/>
                  <field name="is_computed"/>
                  <field name="formula"/>

            </group>
            </group>
        </sheet>
      </form>
    </field>
  </record>

      <record id="view_cost_sheet_template_list" model="ir.ui.view">
        <field name="name">cos.sheet.template.list</field>
        <field name="model">cost.sheet.template</field>
        <field name="arch" type="xml">
            <list>
               <field name="name"/>
              <field name="title"/>
              <field name="code"/>
                  <field name="default_value"/>
                  <field name="formula"/>

            </list>
        </field>
    </record>


     <record id="action_cost_sheet_template" model="ir.actions.act_window">
        <field name="name">Metaliser Cost Sheet</field>
        <field name="res_model">cost.sheet.template</field>
        <field name="view_mode">list,form</field>
        <field name="target">current</field>
        <field name="view_id" ref="view_cost_sheet_template_list"/>
    </record>

     <menuitem
        id="menu_cost_sheet_template"
        name="Metaliser Template(Cost Sheet)"
        parent="sale.sale_order_menu"
        action="action_cost_sheet_template"
        sequence="12"
     groups="group_cost_sheet_templates_modify_access,base.group_system"/>



       <!-- views/Cost sheet Slitted template.xml -->
  <record id="view_cost_sheet_slitted_template_form" model="ir.ui.view">
    <field name="name">cost.sheet</field>
    <field name="model">cs.slitted.template</field>
    <field name="arch" type="xml">
      <form string="Cost Sheet Template">
        <sheet>
            <group>
                <group>
              <field name="name" />
              <field name="title"/>
              <field name="code"/>
              <field name="sequence"/>
              <field name="average_cost"/>

          </group>
            <group>
              <field name="cost_kgs"/>
<!--              <field name="cost_sheet_slit_id"/>-->
                  <field name="default_value"/>
                  <field name="is_computed"/>
                  <field name="formula"/>

            </group>
            </group>
        </sheet>
      </form>
    </field>
  </record>

      <record id="view_cost_sheet_slitted_template_list" model="ir.ui.view">
        <field name="name">cos.sheet.template.list</field>
        <field name="model">cs.slitted.template</field>
        <field name="arch" type="xml">
            <list>
               <field name="name"/>
              <field name="title"/>
              <field name="code"/>
                  <field name="default_value"/>
                  <field name="formula"/>

            </list>
        </field>
    </record>


     <record id="action_cost_sheet_slitted_template" model="ir.actions.act_window">
        <field name="name">Slitted Cost Sheet</field>
        <field name="res_model">cs.slitted.template</field>
        <field name="view_mode">list,form</field>
        <field name="target">current</field>
        <field name="view_id" ref="view_cost_sheet_slitted_template_list"/>
    </record>

     <menuitem
        id="menu_cost_sheet_slitted_template"
        name="Sliited Template(Cost Sheet)"
        parent="sale.sale_order_menu"
        action="action_cost_sheet_slitted_template"
        sequence="12"
       groups="group_cost_sheet_templates_modify_access,base.group_system"/>


</odoo>
<odoo>
    <data>

        <record id="maintenance_request_form_view_inherit" model="ir.ui.view">
            <field name="name">maintenance.request.form.inherit</field>
            <field name="model">maintenance.request</field>
            <field name="inherit_id" ref="maintenance.hr_equipment_request_view_form"/>
            <field name="arch" type="xml">

                <xpath expr="//button[@name='archive_equipment_request']" position="before">
                    <button string="Approve"
                            type="object" name="send_for_cfo_appoval"
                            groups="maintenance.group_equipment_manager"
                            invisible="not show_supervisor_button"
                            class="btn-primary"/>

                    <button string="Maintenance Done"
                            type="object" name="maintenance_approval"
                            groups="famti.group_maintenance_dep_users"
                            invisible="not show_approve_button"
                            class="btn-primary"/>
                    
                    <button string="Submit for Approval"
                            type="object" name="submit_for_approval"
                            groups="base.group_system"
                            invisible="not show_submit_button"
                            class="btn-primary"/>
                            
                    <button name="action_open_track_wizard"
                        string="Track Maintenance"
                        type="object"
                        class="btn-primary"
                        invisible="show_scrap_button"/>

                    <button name="action_scrap_confirm"
                        string="Scrap"
                        type="object"
                        class="btn-secondary"
                        invisible="show_scrap_button"/>

                </xpath>
                <xpath expr="//field[@name='name']" position="attributes">
                    <attribute name="readonly">show_supervisor_button</attribute>
                </xpath>
<!--                <xpath expr="//field[@name='employee_id']" position="replace">-->
<!--                    <field name="employee_id" readonly="1" options="{'no_open': True}"/>-->
<!--                </xpath>-->
    <xpath expr="//field[@name='employee_id']" position="attributes">
    <attribute name="readonly">1</attribute>
    <attribute name="options">{'no_open': True}</attribute>
</xpath>
                <xpath expr="//field[@name='email_cc']" position="attributes">
                    <attribute name="readonly">show_supervisor_button</attribute>
                </xpath>
                <xpath expr="//field[@name='equipment_id']" position="attributes">
                    <attribute name="readonly">show_supervisor_button</attribute>
                    <attribute name="required">1</attribute>
                    <attribute name="options">{'no_open': True}</attribute>
                </xpath>

                <xpath expr="//field[@name='category_id']" position="attributes">
                    <attribute name="readonly">1</attribute>
                    <attribute name="options">{'no_open': True}</attribute>
                </xpath>

                <xpath expr="//field[@name='request_date']" position="attributes">
                    <attribute name="readonly">show_supervisor_button</attribute>
                </xpath>

                <xpath expr="//field[@name='maintenance_type']" position="attributes">
                    <attribute name="readonly">show_supervisor_button</attribute>
                </xpath>

                <xpath expr="//field[@name='maintenance_team_id']" position="attributes">
                    <attribute name="readonly">show_supervisor_button</attribute>
                    <attribute name="required">1</attribute>
                </xpath>

                <xpath expr="//field[@name='user_id']" position="attributes">
                    <attribute name="readonly">show_supervisor_button</attribute>
                    <attribute name="invisible">show_responsible</attribute>
                    <attribute name="options">{'no_open': True}</attribute>
                </xpath>

                <xpath expr="//field[@name='schedule_date']" position="attributes">
                    <attribute name="readonly">show_supervisor_button</attribute>
                    <attribute name="required">1</attribute>
                </xpath>

                <xpath expr="//field[@name='duration']" position="attributes">
                    <attribute name="readonly">show_supervisor_button</attribute>
                </xpath>

                <xpath expr="//field[@name='recurring_maintenance']" position="attributes">
                    <attribute name="readonly">show_supervisor_button</attribute>
                </xpath>

                <xpath expr="//field[@name='repeat_interval']" position="attributes">
                    <attribute name="readonly">show_supervisor_button</attribute>
                </xpath>

                <xpath expr="//field[@name='repeat_unit']" position="attributes">
                    <attribute name="readonly">show_supervisor_button</attribute>
                </xpath>

                <xpath expr="//field[@name='repeat_type']" position="attributes">
                    <attribute name="readonly">show_supervisor_button</attribute>
                </xpath>

                <xpath expr="//field[@name='repeat_until']" position="attributes">
                    <attribute name="readonly">show_supervisor_button</attribute>
                </xpath>

                <xpath expr="//field[@name='priority']" position="attributes">
                    <attribute name="readonly">show_supervisor_button</attribute>
                    <attribute name="required">1</attribute>
                </xpath>

                <xpath expr="//sheet//field[@name='company_id']" position="attributes">
                    <attribute name="readonly">show_supervisor_button</attribute>
                    <attribute name="options">{'no_open': True}</attribute>
                </xpath>

                <xpath expr="//field[@name='user_id']" position="after">
                    <field name="contractor_id" invisible="not show_responsible" readonly="show_supervisor_button"/>
                    <field name="contractor_phone" readonly="show_supervisor_button"/>
                    <field name="email" readonly="show_supervisor_button"/>
                </xpath>
                <xpath expr="//field[@name='stage_id']" position="replace">
                    <field name="stage_id" widget="statusbar" options="{'clickable': 0}" invisible="archive"/>
                </xpath>

                <xpath expr="//field[@name='request_date']" position="after">
                    <field name="start_datetime" readonly="show_supervisor_button"/>
                    <label for="expected_duration"/>
                    <div>
                        <field name="expected_duration" widget="float_time" readonly="show_supervisor_button" required="1" class="oe_inline"/> <span class="ml8">hours</span>
                    </div>
                </xpath>
                <xpath expr="//field[@name='schedule_date']" position="after">
                    <field name="end_datetime" readonly="show_supervisor_button"/>
                </xpath>

                <xpath expr="//notebook" position="inside">
                    <page string="Track Maintenance">
                        <field name="track_ids">
                            <list editable="bottom">
                                <field name="team_id"/>
                                <field name="priority" widget="priority"/>
                                <field name="request_date"/>
                                <field name="start_datetime"/>
                                <field name="end_datetime"/>
                                <field name="expected_duration"/>
                                <field name="duration"/>
                                <field name="state" widget="badge"/>
                                <button name="action_open_record" type="object" icon="fa-list"
                                    class="btn-link"/>
                            </list>
                        </field>
                    </page>
                </xpath>

            </field>
        </record>
        
        <record id="view_maintenance_track_form" model="ir.ui.view">
            <field name="name">maintenance.track.form</field>
            <field name="model">maintenance.track</field>
            <field name="arch" type="xml">
                <form string="Track Maintenance">
                    <header>
                        <field name="state"
                            widget="statusbar"
                            statusbar_visible="new,to_approve,in_progress,repaired,scrap"
                            options="{'clickable': '1'}"/>
                    </header>

                    <div class="oe_title">
                        <h1>
                            <field name="maintenance_id" readonly="1"
                                placeholder="e.g. Screen not working"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="team_id"/>
                            <field name="user_id" invisible="show_responsible"/>
                            <field name="contractor_id" invisible="not show_responsible"/>
                            <label for="expected_duration"/>
                            <div>
                                <field name="expected_duration" widget="float_time" class="oe_inline"/>
                                <span class="ml8">hours</span>
                            </div>
                            <field name="request_date"/>
                            <field name="schedule_date"/>                            
                        </group>

                        <group>
                            <field name="priority" widget="priority"/>
                            <field name="phone"/>
                            <field name="email"/>
                            <label for="duration"/>
                            <div>
                                <field name="duration" widget="float_time" class="oe_inline"/>
                                <span class="ml8">hours</span>
                            </div>
                            <field name="start_datetime"/>
                            <field name="end_datetime"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Notes">
                            <field name="notes" placeholder="Internal Notes"/>
                        </page>
                    </notebook>

                </form>
            </field>
        </record>
    </data>
</odoo>

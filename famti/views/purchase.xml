<odoo>
    <data>

         <record id="purchase_form_view_inherit" model="ir.ui.view">
            <field name="name">purchase.order.form.inherit</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_form"/>
            <field name="arch" type="xml">



                <xpath expr="//div[hasclass('oe_button_box')]" position="inside">
                <button type="object"
                    name="action_view_freight_orders"
                    class="oe_stat_button"
                    icon="fa-ship" invisible="is_shipped or state not in ('purchase', 'done')">

                    <field name="freight_count"
                           widget="statinfo"
                           string="Freight"/>
                </button>
                </xpath>



                <xpath expr="//sheet/div[@class='oe_title']" position="inside">
                    <div class="oe_avatar_container" style="position:absolute; right:16px; top:4px;">
                        <field name="logo"
                               widget="image"
                               class="oe_avatar"
                               options='{"zoom": true}'/>
                    </div>
                </xpath>

                <xpath expr="//form/header/button[@name='button_confirm' and @id='bid_confirm']"
                    position="attributes">
                    <attribute name="invisible">True</attribute>
                </xpath>

                <xpath expr="//form/header/button[@name='button_confirm' and @id='draft_confirm']"
                    position="attributes">
                    <attribute name="invisible">True</attribute>
                </xpath>

                <xpath expr="//button[@name='button_confirm']" position="before">
                  <button string="CFO Approval"
                          name="action_send_for_cfo_approval"
                          type="object"
                          invisible="state in ['to approve','purchase']"
                          groups="famti.group_purchase_dep_users,purchase.group_purchase_manager"
                          class="btn-primary"/>

                </xpath>

                <xpath expr="//field[@name='partner_id']" position="after">
                    <span class="o_form_label o_td_label o_address_type">
                        <span>Address</span>
                    </span>
                    <div class="o_address_format">
                        <field name="vendor_street" placeholder="Street..." class="o_address_street"/>
                        <field name="vendor_street2" placeholder="Street 2..." class="o_address_street"/>
                        <field name="vendor_city" placeholder="City" class="o_address_city"/>
                        <field name="vendor_state_id" class="o_address_state" placeholder="State"
                            options="{'no_open': True, 'no_quick_create': True}" context="{'country_id': vendor_country_id}"/>
                        <field name="vendor_zip" placeholder="ZIP" class="o_address_zip"/>
                        <div class="d-flex justify-content-between">
                            <field name="vendor_country_id" placeholder="Country" class="o_address_country"
                                options="{'no_open': True, 'no_create': True}"/>
                        </div>
                    </div>
                    <field name="vendor_vat" placeholder="VAT / GST"/>
                    <field name="vendor_email" placeholder="Vendor Email"/>
                    <field name="vendor_phone" placeholder="Contact Number"/>
                </xpath>
                 <xpath expr="//field[@name='partner_id']" position="attributes">
                    <attribute name="options">{'no_open': True}</attribute>
                </xpath>

                <xpath expr="//field[@name='currency_id']" position="attributes">
                    <attribute name="options">{'no_open': True}</attribute>
                </xpath>
                <xpath expr="//field[@name='picking_type_id']" position="attributes">
                    <attribute name="options">{'no_open': True}</attribute>
                </xpath>

                <xpath expr="//field[@name='partner_id']" position="attributes">
                    <attribute name="readonly">state != 'draft'</attribute>
                </xpath>
                <xpath expr="//field[@name='partner_ref']" position="attributes">
                    <attribute name="readonly">state != 'draft'</attribute>
                </xpath>
                <xpath expr="//field[@name='date_order']" position="attributes">
                    <attribute name="readonly">state != 'draft'</attribute>
                </xpath>
                <xpath expr="//field[@name='date_planned']" position="attributes">
                    <attribute name="readonly">state != 'draft'</attribute>
                </xpath>
                <xpath expr="//field[@name='picking_type_id']" position="attributes">
                    <attribute name="readonly">state != 'draft'</attribute>
                </xpath>

                <xpath expr="//field[@name='picking_type_id']" position="before">
                    <field name="po_type"/>
                    <field name="payment_term_id" required="1"/>
                    <field name="incoterm_id" string="Delivery terms" required="1"/>
                </xpath>

                <xpath expr="//field[@name='order_line']/list/field[@name='product_id']" position="after">
                    <field name="description"/>
                    <field name="treatment_in" column_invisible="parent.is_tolling"/>
                    <field name="treatment_out" column_invisible="parent.is_tolling"/>
                    <field name="thickness_val"  column_invisible="parent.is_tolling"/>
                    <field name="thickness_uom" no_label="1"  column_invisible="parent.is_tolling"/>
                    <field name="width_val"  column_invisible="parent.is_tolling"/>
                    <field name="width_uom" no_label="1"  column_invisible="parent.is_tolling"/>
                    <field name="pieces"  column_invisible="parent.is_tolling"/>
                    <field name="core_id"  column_invisible="parent.is_tolling"/>
                    <field name="length_val"  column_invisible="parent.is_tolling"/>
                    <field name="length_uom" no_label="1"  column_invisible="parent.is_tolling"/>
                    <field name="category"  optional="hide"  column_invisible="parent.is_tolling"/>
                    <field name="film"  optional="hide"  column_invisible="parent.is_tolling"/>
                    <field name="film_type" optional="hide"  column_invisible="parent.is_tolling"/>
                </xpath>
                <xpath expr="//field[@name='order_line']/list/field[@name='taxes_id']" position="before">
                    <field name="remarks"/>
                </xpath>

                <xpath expr="//field[@name='order_line']/list/field[@name='qty_invoiced']" position="after">
                    <field name="rolls_uom_id" column_invisible="parent.po_type != 'fgf'"/>
                </xpath>
                <xpath expr="(//field[@name='order_line']/list/field[@name='product_uom'])[1]" position="attributes">
                    <attribute name="column_invisible">parent.po_type == 'fgf'</attribute>
                </xpath>

                <xpath expr="(//field[@name='order_line']/list/field[@name='product_uom'])[2]" position="attributes">
                    <attribute name="column_invisible">parent.po_type == 'fgf'</attribute>
                </xpath>

                <xpath expr="//page[@name='purchase_delivery_invoice']//group[@name='other_info']/field[@name='incoterm_location']" position="after">
                    <field name="remarks"/>
                </xpath>

                <control>
                    <button name="action_open_uom_conversion" string="Convert UOM" type="object" class="px-4 btn-link" context="{'order_id': parent.id}"/>
                </control>

            </field>
        </record>



    </data>
</odoo>

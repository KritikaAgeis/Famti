<odoo>
    <record id="view_cost_sheet_form" model="ir.ui.view">
        <field name="name">famti.cost.sheet.form</field>
        <field name="model">cost.sheet</field>
        <field name="arch" type="xml">

            <form string="Cost Sheet">
                <header>
<!--                    <button name="action_submit" string="Send to CFO" type="object"-->
<!--                            states="draft" class="btn-primary"/>-->

<!--                    <button name="action_approve" string="Approve" type="object"-->
<!--                            states="submitted" class="btn-success"/>-->

<!--                    <button name="action_reject" string="Reject" type="object"-->
<!--                            states="submitted" class="btn-danger"/>-->
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,approved,rejected"/>
                </header>

                <sheet>
                    <group>
                        <group>
                            <field name="sale_order_id"/>
                            <field name="partner_id"/>
                            <field name="product_id"/>
                            <field name="qty"/>
                        </group>

                        <group>
                            <field name="selling_price"/>
                            <field name="wastage_percent"/>
                        </group>
                    </group>

                    <notebook>

                        <page string="Cost Sheet 1">
                            <field name="template_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="code" readonly="1"/>
                                    <field name="uom"/>
                                    <field name="default_value"/>
                                    <field name="formula" readonly="1"/>
                                </list>
                            </field>
                        </page>

                        <page string="Cost Sheet">
                            <field name="cost_template_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="code" readonly="1"/>
                                    <field name="uom"/>
                                    <field name="default_value"/>
                                    <field name="formula" readonly="1"/>
                                </list>
                            </field>
                        </page>

                        <page string="Cost Details">
                            <group>
                                <field name="raw_material_cost"/>
                                <field name="metallization_cost"/>
                                <field name="slitting_cost"/>
                                <field name="packing_cost"/>
                                <field name="logistics_cost"/>
                            </group>
                        </page>

                        <page string="Summary">
                            <group>
                                <field name="total_cost_per_kg" readonly="1"/>
                                <field name="total_cost" readonly="1"/>
                                <field name="profit_per_kg" readonly="1"/>
                                <field name="total_profit" readonly="1"/>
                            </group>
                        </page>

                    </notebook>
                </sheet>
            </form>
        </field>
    </record>


    <record id="view_cost_sheet_list" model="ir.ui.view">
        <field name="name">cost.sheet.list</field>
        <field name="model">cost.sheet</field>
        <field name="arch" type="xml">
            <list>
                <field name="sale_order_id"/>
                <field name="product_id"/>

            </list>
        </field>
    </record>

    <record id="action_cost_sheet_form" model="ir.actions.act_window">
        <field name="name">COST SHEET</field>
        <field name="res_model">cost.sheet</field>
        <field name="view_mode">list,form</field>
<!--        <field name="target">current</field>-->
    </record>

    <menuitem
        id="menu_costing_sheet"
        name="Cost Sheet"
        parent="sale.sale_order_menu"
        action="action_cost_sheet_form"
        sequence="11"/>


</odoo>
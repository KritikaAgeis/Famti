<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_hr_resignation_list" model="ir.ui.view">
        <field name="name">hr.resignation.list</field>
        <field name="model">hr.resignation</field>
        <field name="arch" type="xml">
            <list>
                <field name="employee_id"/>
                <field name="resignation_date"/>
                <field name="contract_id"/> 
                <field name="department_id"/> 
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_hr_resignation_form" model="ir.ui.view">
        <field name="name">hr.resignation.form</field>
        <field name="model">hr.resignation</field>
        <field name="arch" type="xml">
            <form string="Resignation">

                <header>
                    <button name="action_submit" type="object" string="Submit"
                            class="btn-primary"
                            invisible="state != 'draft'"/>

                    <button name="action_approve" type="object" string="Approve"
                            class="btn-primary"
                            invisible="state != 'waiting_for_approval'"
                            groups="famti.group_for_hr_executive"/>

                    <button name="action_reject" type="object" string="Reject"
                            class="btn-secondary"
                            invisible="state != 'waiting_for_approval'"
                            groups="famti.group_for_hr_executive"/>

                    <field name="state" widget="statusbar"
                        statusbar_visible="draft,waiting_for_approval,approved,rejected"/>
                </header>

                <sheet>
                    <group>
                        <group>
                            <field name="employee_id" readonly="state in ['waiting_for_approval','approved','rejected']" required="1"/>
                            <field name="department_id" readonly="1"/>
                            <field name="manager_id" readonly="1"/>
                            <field name="contract_id" readonly="1"/>                              
                            <field name="resignation_type" readonly="state in ['waiting_for_approval','approved','rejected']"/>                          
                        </group>

                        <group>
                            <field name="joining_date" readonly="1"/>
                            <field name="resignation_date" readonly="state in ['waiting_for_approval','approved','rejected']" required="1"/>
                            <field name="notice_period" readonly="state in ['approved','rejected']"/>
                            <field name="approved_last_date" readonly="state in ['approved','rejected']"/>
                            <field name="remarks" invisible="state != 'rejected'"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="reason of resignation">
                            <field name="reason" readonly="state in ['approved','rejected']" required="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_hr_resignation_kanban" model="ir.ui.view">
        <field name="name">hr.resignation.kanban</field>
        <field name="model">hr.resignation</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="employee_id"/>
                <field name="resignation_date"/>
                <field name="department_id"/>
                <field name="state"/>

                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_card">

                            <div class="o_kanban_details">
                                <strong>
                                    <field name="employee_id"/>
                                </strong>

                                <div>
                                    <span>Department: </span>
                                    <field name="department_id"/>
                                </div>

                                <div>
                                    <span>Resignation Date: </span>
                                    <field name="resignation_date"/>
                                </div>

                                <div>
                                    <span>Status: </span>
                                    <field name="state"/>
                                </div>
                            </div>

                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_hr_resignation" model="ir.actions.act_window">
        <field name="name">Resignation</field>
        <field name="res_model">hr.resignation</field>
        <field name="view_mode">list,form</field>
    </record>


    <record id="view_employee_resignation_list" model="ir.ui.view">
        <field name="name">employee.resignation.list</field>
        <field name="model">employee.resignation</field>
        <field name="arch" type="xml">
            <list>
                <field name="employee_id"/>
                <field name="resignation_date"/>
                <field name="contract_id"/> 
                <field name="department_id"/> 
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_employee_resignation_form" model="ir.ui.view">
        <field name="name">employee.resignation.form</field>
        <field name="model">employee.resignation</field>
        <field name="arch" type="xml">
            <form string="Resignation">

                <header>
                    <button name="action_submit" type="object" string="Submit"
                            class="btn-primary"
                            invisible="state != 'draft'"/>

                    <button name="action_approve" type="object" string="Approve"
                            class="btn-primary"
                            invisible="state != 'waiting_for_approval'"
                            groups="famti.group_for_hr_executive"/>

                    <button name="action_reject" type="object" string="Reject"
                            class="btn-secondary"
                            invisible="state != 'waiting_for_approval'"
                            groups="famti.group_for_hr_executive"/>

                    <field name="state" widget="statusbar"
                        statusbar_visible="draft,waiting_for_approval,approved,rejected"/>
                </header>

                <sheet>
                    <group>
                        <group>
                            <field name="employee_id" readonly="state in ['waiting_for_approval','approved','rejected']" required="1"/>
                            <field name="department_id" readonly="1"/>
                            <field name="manager_id" readonly="1"/>
                            <field name="contract_id" readonly="1"/>                              
                            <field name="resignation_type" readonly="state in ['waiting_for_approval','approved','rejected']"/>                          
                        </group>

                        <group>
                            <field name="joining_date" readonly="1"/>
                            <field name="resignation_date" readonly="state in ['waiting_for_approval','approved','rejected']" required="1"/>
                            <field name="notice_period" readonly="state in ['approved','rejected']"/>
                            <field name="approved_last_date" readonly="state in ['approved','rejected']"/>
                            <field name="remarks" invisible="state != 'rejected'"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="reason of resignation">
                            <field name="reason" readonly="state in ['approved','rejected']" required="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_employee_resignation" model="ir.actions.act_window">
        <field name="name">Resignation</field>
        <field name="res_model">employee.resignation</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem 
        id="menu_hr_resignation"
        name="Resignation"
        parent="hr.menu_hr_root"
        sequence="25"
        action="action_employee_resignation"
    />
    

</odoo>

<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_quickbook_config_list" model="ir.ui.view">
        <field name="name">quickbook.config.list</field>
        <field name="model">quickbook.config</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="client_id"/>
                <field name="client_secret"/>
                <field name="redirect_uri"/>
                <field name="realm_id"/>
            </list>
        </field>
    </record>

    <record id="view_quickbook_config_form" model="ir.ui.view">
        <field name="name">quickbook.config.form</field>
        <field name="model">quickbook.config</field>
        <field name="arch" type="xml">
            <form string="Quickbook Config">
                

                <header>
<!--                    <button name="action_submit" type="object" string="Submit"-->
<!--                            class="btn-primary"-->
<!--                            invisible="state != 'draft'"/>-->

<!--                    <button name="action_approve" type="object" string="Approve"-->
<!--                            class="btn-success"-->
<!--                            invisible="state != 'waiting_for_approval'"/>-->

                    <button name="action_connect" type="object" string="Connect"
                            class="btn-success"
                            />

                    <field name="status" widget="statusbar"
                        statusbar_visible="draft,connected,disconnected"/>
                </header>
                
                <sheet>

                    <widget name="web_ribbon"
                            title="Connected"
                            bg_color="bg-success"
                            invisible="status != 'connected'"/>

                    <widget name="web_ribbon"
                            title="Disconnected"
                            bg_color="bg-danger"
                            invisible="status != 'disconnected'"/>

                    <widget name="web_ribbon"
                            title="Draft"
                            bg_color="bg-warning"
                            invisible="status != 'draft'"/>

                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="QuickBooks Configuration"/>
                        </h1>
                    </div>

                    <notebook>
                        <page string="API Configuration">

                            <group>
                                <group string="Credentials">
                                    <field name="client_id"/>
                                    <field name="client_secret" password="True"/>
                                    <field name="redirect_uri"/>
                                    <field name="realm_id" />
                                </group>

                                <group string="Tokens">
                                    <field name="access_token" />
                                    <field name="refresh_token" />
                                </group>
                            </group>

                        </page>
                    </notebook>

                </sheet>

            </form>
        </field>
    </record>

    <record id="action_quickbook_config" model="ir.actions.act_window">
        <field name="name">QuickBook Configuration</field>
        <field name="res_model">quickbook.config</field>
        <field name="view_mode">list,form</field>
    </record>



    <menuitem
        id="menu_root_quickbook"
        name="QuickBook"
        sequence="2"
        action="action_quickbook_config"
        groups="base.group_system"
    />

    <menuitem
        id="menu_quickbook"
        name="QuickBook Config"
        sequence="3"
        action="action_quickbook_config"
        parent="menu_root_quickbook"
        groups="base.group_system"
    />

</odoo>

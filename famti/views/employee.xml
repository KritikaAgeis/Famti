<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_employee_form_documents" model="ir.ui.view">
            <field name="name">hr.employee.form.documents</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">

                <xpath expr="//page[@name='personal_information']" position="after">
                    <page string="Related Documents">
                        <field name="document_ids">
                            <list editable="bottom">
                                <field name="document_name"/>
                                <field name="document_file" filename="document_filename"/>
                                <field name="uploaded_by" readonly="1"/>
                            </list>
                        </field>
                    </page>
                </xpath>
                <xpath expr="//field[@name='work_email']" position="before">
                    <label for="barcode"/>
                    <div class="o_row">
                        <field name="barcode" string="Employee Id"/>
                        <button string="Generate" class="btn btn-link" type="object" name="generate_random_barcode" invisible="barcode"/>
                        <button name="357" string="Print Badge" class="btn btn-link" type="action" invisible="not barcode"/>
                    </div>
                </xpath>
                <xpath expr="//page[@name='public']//group[.//field[@name='work_location_id']]" position="after">
                    <group string="Employment Details">
                        <group>
                            <field name="joining_date" required="1"/>
                        </group>
                        <group>
                        </group>
                        <group>
                            <field name="training_start_date" required="1"/>
                            <field name="probation_start_date"/>
                        </group>
                        <group>
                            <field name="training_end_date"/>
                            <field name="probation_end_date"/>
                        </group>
                    </group>
                </xpath>

                <xpath expr="//header" position="inside">
                    <button name="action_open_wsib_wizard"
                            type="object"
                            string="WSIB Tracking"
                            class="btn-primary"/>
                    
                    <button name="action_start_training" type="object" string="Start Training" class="btn-secondary"
                        invisible="state != 'draft'"/>

                    <button name="action_training_completed" type="object" string="Training Completed" class="btn-secondary"
                        invisible="state != 'training'"/>

                    <button name="action_certified" type="object" string="Certified" class="btn-secondary"
                        invisible="state != 'completed_training'"/>
                    
                    <button name="action_confirm_probation" type="object" string="Regular Employee" class="btn-secondary"
                        invisible="state != 'probation'"/>

                    <field name="state" widget="statusbar"
                        statusbar_visible="draft,training,completed_training,probation,regular"/>
                </xpath>
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="action_view_wsib_cases"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-file">

                        <field name="wsib_case_count" widget="statinfo"/>
                    </button>
                </xpath>

                <xpath expr="//notebook" position="inside">
                    <page string="WSIB Tracking">
                        <field name="wsib_case_ids">
                            <list editable="bottom">
                                <field name="incident_date"/>
                                <field name="report_type"/>
                                <field name="state" widget="badge"/>
                                <button name="action_open_record" type="object" icon="fa-list"
                                    class="btn-link"/>
                            </list>
                        </field>
                    </page>
                </xpath>

            </field>
        </record>

        <record id="view_employee_public_documents" model="ir.ui.view">
            <field name="name">hr.employee.public.documents</field>
            <field name="model">hr.employee.public</field>
            <field name="inherit_id" ref="hr.hr_employee_public_view_form"/>
            <field name="arch" type="xml">

                <xpath expr="//notebook" position="inside">
                    <page string="Related Documents" invisible="user_id != uid">
                        <field name="document_ids">
                            <list editable="bottom">
                                <field name="document_name"/>
                                <field name="document_file" filename="document_filename"/>
                                <field name="uploaded_by" readonly="1"/>
                            </list>
                        </field>
                    </page>
                </xpath>
                <!-- <xpath expr="//page[@name='public']" position="attributes">
                    <attribute name="invisible">user_id != uid</attribute>
                </xpath>
                <xpath expr="//page[@name='skills_resume']" position="attributes">
                    <attribute name="invisible">user_id != uid</attribute>
                </xpath> -->
                <xpath expr="//notebook" position="attributes">
                    <attribute name="invisible">user_id != uid</attribute>
                </xpath>

                <xpath expr="//notebook" position="inside">
                    <page string="WSIB Tracking" invisible="user_id != uid">
                        <field name="wsib_case_ids">
                            <list editable="bottom">
                                <field name="incident_date"/>
                                <field name="report_type"/>
                                <field name="state" widget="badge"/>
                            </list>
                        </field>
                    </page>
                </xpath>
                

            </field>
        </record>

        <!-- <record id="employee_public_see_own" model="ir.rule">
            <field name="name">Employee Public: see own</field>
            <field name="model_id" ref="hr.model_hr_employee_public"/>
            <field name="domain_force">[('user_id','=',user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record> -->

        <record id="view_wsib_case_form" model="ir.ui.view">
            <field name="name">wsib.case.form</field>
            <field name="model">wsib.case</field>
            <field name="arch" type="xml">
                <form string="WSIB Tracking">

                    <header>
                        <field name="state" widget="statusbar"
                            statusbar_visible="draft,submitted,under_review,approved,rejected,closed"/>

                        <button name="action_start_review" type="object"
                                string="Start Review"
                                invisible="state != 'submitted'"/>

                        <button name="action_approve" type="object"
                                string="Approve"
                                invisible="state != 'under_review'"/>

                        <button name="action_reject" type="object"
                                string="Reject"
                                invisible="state != 'under_review'"/>

                        <button name="action_close" type="object"
                                string="Close"/>
                    </header>

                    <sheet>
                        <group>
                            <group>
                                <field name="employee_id"/>
                                <field name="department_id"/>
                                <field name="job_id"/>
                                <field name="report_type"/>
                            </group>

                            <group>
                                <field name="manager_id"/>
                                <field name="coach_id"/>
                                <field name="incident_date"/>
                                <field name="report_document" filename="report_filename"/>
                            </group>
                            <field name="description" placeholder="Explain the incident clearly (location, cause, and impact)..."/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        
        <record id="view_wsib_case_list" model="ir.ui.view">
            <field name="name">wsib.case.list</field>
            <field name="model">wsib.case</field>
            <field name="arch" type="xml">
                <list string="WSIB Tracking">
                    <field name="employee_id"/>
                    <field name="incident_date"/>
                    <field name="report_type"/>
                    <field name="state" widget="badge"/>

                </list>
            </field>
        </record>

        
    </data>
</odoo>

<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_employee_form_documents" model="ir.ui.view">
            <field name="name">hr.employee.form.documents</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">

                <xpath expr="//page[@name='personal_information']" position="after">
                    <page string="Related Documents">
                        <field name="document_ids">
                            <list editable="bottom">
                                <field name="document_name"/>
                                <field name="document_file" filename="document_filename"/>
                                <field name="uploaded_by" readonly="1"/>
                            </list>
                        </field>
                    </page>
                </xpath>
                <xpath expr="//field[@name='work_email']" position="before">
                    <label for="barcode"/>
                    <div class="o_row">
                        <field name="barcode" string="Employee Id"/>
                        <button string="Generate" class="btn btn-link" type="object" name="generate_random_barcode" invisible="barcode"/>
                        <button name="357" string="Print Badge" class="btn btn-link" type="action" invisible="not barcode"/>
                    </div>
                </xpath>
                <xpath expr="//page[@name='public']//group[.//field[@name='work_location_id']]" position="after">
                    <group string="Employment Details">
                        <group>
                            <field name="joining_date"/>
                        </group>
                        <group>
                        </group>
                        <group>
                            <field name="training_start_date"/>
                            <field name="probation_start_date"/>
                        </group>
                        <group>
                            <field name="training_end_date"/>
                            <field name="probation_end_date"/>
                        </group>
                    </group>
                </xpath>

            </field>
        </record>

        <record id="view_employee_public_documents" model="ir.ui.view">
            <field name="name">hr.employee.public.documents</field>
            <field name="model">hr.employee.public</field>
            <field name="inherit_id" ref="hr.hr_employee_public_view_form"/>
            <field name="arch" type="xml">

                <xpath expr="//notebook" position="inside">
                    <page string="Related Documents" invisible="user_id != uid">
                        <field name="document_ids">
                            <list editable="bottom">
                                <field name="document_name"/>
                                <field name="document_file" filename="document_filename"/>
                                <field name="uploaded_by" readonly="1"/>
                            </list>
                        </field>
                    </page>
                </xpath>
                <!-- <xpath expr="//page[@name='public']" position="attributes">
                    <attribute name="invisible">user_id != uid</attribute>
                </xpath>
                <xpath expr="//page[@name='skills_resume']" position="attributes">
                    <attribute name="invisible">user_id != uid</attribute>
                </xpath> -->
                <xpath expr="//notebook" position="attributes">
                    <attribute name="invisible">user_id != uid</attribute>
                </xpath>
                

            </field>
        </record>

        <!-- <record id="employee_public_see_own" model="ir.rule">
            <field name="name">Employee Public: see own</field>
            <field name="model_id" ref="hr.model_hr_employee_public"/>
            <field name="domain_force">[('user_id','=',user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record> -->

        
    </data>
</odoo>

<odoo>
    <record id="view_move_form_hide_uom_fgf" model="ir.ui.view">
        <field name="name">account.move.form.hide.uom.fgf</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='product_uom_id']" position="attributes">
                <attribute name="column_invisible">parent.so_type == 'fgf' or parent.po_type == 'fgf'</attribute>
            </xpath>
            <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='quantity']" position="after">
                <field name="pieces" column_invisible="parent.so_type != 'fgf'"/>
                <field name="pieces_po" column_invisible="parent.po_type != 'fgf'"/>
                <field name="rolls_uom_id" column_invisible="parent.so_type != 'fgf' and parent.po_type != 'fgf'"/>
            </xpath>
            <xpath expr="//field[@name='delivery_date']" position="before">
                <field name="invoice_incoterm_id" string="Delivery terms" readonly="state in ['cancel', 'posted']"/>
                <field name="ship_via"/>
                <field name="quickbook_id" readonly="1"/>

            </xpath>
            

        </field>
    </record>
</odoo>

<odoo>
    <data>
        <record id="res_partner_form_view_inherit" model="ir.ui.view">
            <field name="name">res.partner.form.inherit</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">

                <xpath expr="//sheet" position="before">
                    <header>
                        <field name="state"
                            widget="statusbar"
                            statusbar_visible="draft,verified_vendor,certificate_expired"
                            invisible="is_supplier == 0"/>

                        <button name="action_iso_certificate_updated"
                            string="Verify Certificate"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft' or is_supplier == 0"/>

                        <button name="action_iso_certificate_renew"
                            string="Certificate renewed"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'certificate_expired'"/>
                    </header>
                </xpath>

                <xpath expr="//field[@name='title']" position="after">
                  <field name="is_supplier" invisible="1"/>
                  <field name="company_id" options="{'no_open': True}"/>
                </xpath>

                <xpath expr="//group/group" position="inside">
                    <field name="iso_vendor_certificate"
                        filename="iso_certificate_name"
                        invisible="is_supplier == 0"/>
                    <field name="vendor_document_expiry" widget="remaining_days" string="Certificate Expiry"
                        invisible="is_supplier == 0 or not iso_vendor_certificate"/>
                </xpath>  

                <xpath expr="//notebook" position="inside">
                    <page string="Credit Control">

                        <group>
                            <field name="credit"/>
                            <field name="days_sales_outstanding"/>
                            <label for="use_partner_credit_limit"/>
                            <div class="o_row">
                                <field name="use_partner_credit_limit"/>
                                <field name="credit_limit" class="oe_inline" widget="monetary" options="{'currency_field': 'currency_id'}" invisible="not use_partner_credit_limit"/>
                            </div>
                            <field name="credit_grace_days"/>
                            <field name="lc_document" widget="binary" invisible="is_supplier == 1"/>
                        </group>

                    </page>
                </xpath>             


            </field>
        </record>


        <record id="action_customers" model="ir.actions.act_window">
            <field name="name">Customers</field>
            <field name="res_model">res.partner</field>
            <field name="view_mode">kanban,list,form</field>
            <!-- <field name="domain">[('customer_rank', '>', 0)]</field> -->
            <field name="domain">[('is_supplier','=',False)]</field>
            <field name="context">
                {
                    'default_is_supplier': False
                }
            </field>
        </record>


        <record id="action_vendors" model="ir.actions.act_window">
            <field name="name">Vendors</field>
            <field name="res_model">res.partner</field>
            <field name="view_mode">kanban,list,form</field>
            <!-- <field name="domain">[('supplier_rank', '>', 0)]</field> -->
            <field name="domain">[('is_supplier','=',True)]</field>
            <field name="context">
                {
                    'default_is_supplier': True
                }
            </field>
        </record>

         <!-- <record id="view_res_partner_form_credit_controls" model="ir.ui.view">
        <field name="name">res.partner.form.credit.controls</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='accounting']" position="inside">
                <group string="Credit Control">
                    <group>
                        <field name="credit_grace_days"/>
                    </group>
                    <group>
                        <field name="lc_document" widget="binary" invisible="is_supplier == 1"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record> -->


    <record id="view_res_partner_bank_form_inherit_famti" model="ir.ui.view">
        <field name="name">res.partner.bank.form.inherit.famti</field>
        <field name="model">res.partner.bank</field>
        <field name="inherit_id" ref="base.view_partner_bank_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='acc_number']" position="after">
                <field name="transit_no"/>
                <field name="institution_no"/>
            </xpath>

        </field>
    </record>

    <record id="contacts.menu_contacts" model="ir.ui.menu">
        <field name="name">All Contacts</field>
    </record>

    <record id="menu_contacts_customers" model="ir.ui.menu">
        <field name="name">Customers</field>
        <field name="parent_id" ref="contacts.menu_contacts"/>
        <field name="action" ref="action_customers"/>
        <field name="sequence">1</field>
    </record>

    <record id="menu_contacts_vendors" model="ir.ui.menu">
        <field name="name">Vendors</field>
        <field name="parent_id" ref="contacts.menu_contacts"/>
        <field name="action" ref="action_vendors"/>
        <field name="sequence">1</field>
    </record>

    <record id="view_customer_visit_form" model="ir.ui.view">
        <field name="name">customer.visit.form</field>
        <field name="model">customer.visit</field>
        <field name="arch" type="xml">
            <form string="Customer Visit">
                <sheet>

                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="visit_date"/>
                            <field name="user_id"/>
                            <field name="contact_person"/>
                            <field name="designation"/>
                            <field name="product_ids" widget="many2many_tags"/>
                        </group>

                            
                            <group>

                                <field name="company_name"/>
                                <div class="o_address_format">

                                    <field name="street" placeholder="Street..." class="o_address_street"/>
                                    <field name="street2" placeholder="Street 2..." class="o_address_street"/>

                                    <field name="city" placeholder="City" class="o_address_city"/>

                                    <field name="state_id"
                                        class="o_address_state"
                                        placeholder="State"
                                        options="{'no_open': True, 'no_create': True}"
                                        context="{'country_id': country_id}"/>

                                    <field name="zip" placeholder="ZIP" class="o_address_zip"/>

                                    <div class="d-flex justify-content-between">
                                        <field name="country_id"
                                            placeholder="Country"
                                            class="o_address_country"
                                            options="{'no_open': True, 'no_create': True}"/>
                                    </div>

                                </div>
                                <field name="phone"/>
                                <field name="email"/>

                            </group>
                            
                    </group>


                    <notebook>
                        <page string="Visit Details">
                            <group>
                                <group>
                                    <field name="purpose"/>
                                    <field name="action_items"/>
                                </group>

                                <group>
                                    <field name="summary"/>
                                </group>                                                                                                
                            </group>
                        </page>
                    </notebook>

                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
   
   <record id="view_customer_visit_list" model="ir.ui.view">
        <field name="name">customer.visit.list</field>
        <field name="model">customer.visit</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="visit_date"/>
                <field name="company_name"/>
                <field name="contact_person"/>
                <field name="designation"/>
                <field name="user_id"/>
            </list>
        </field>
    </record>

    <record id="action_customer_visit" model="ir.actions.act_window">
        <field name="name">Customer Visits</field>
        <field name="res_model">customer.visit</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_customer_visit"
          name="Customer Visits"
          parent="contacts.menu_contacts"
          action="action_customer_visit"/>

    </data>
</odoo>

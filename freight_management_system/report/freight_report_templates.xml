<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--    For freight order report-->
    <record id="report_freight" model="ir.actions.report">
        <field name="name">Freight Order</field>
        <field name="model">freight.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">freight_management_system.report_freight_order</field>
        <field name="report_file">freight_management_system.report_freight_order</field>
        <field name="print_report_name">'Freight Order - %s' % object.name</field>
        <field name="binding_model_id" ref="model_freight_order"/>
        <field name="binding_type">report</field>
    </record>
    <!--    Report Template-->
    <template id="report_freight_order">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">

                    <div style="width:100%; margin-bottom:20px;">

                        <div style="text-align:center; background:#e6e6e6; padding:8px; margin-bottom:10px;">
                            <strong style="font-size:14px; letter-spacing:1px;">
                                FREIGHT ORDER / SHIPPING INSTRUCTION
                            </strong>
                        </div>

                        <div style="width:100%; border-bottom:2px solid #000; padding-bottom:8px;">

                            <div style="float:left; width:70%;">
                                <h1 style="margin:0; font-size:22px;">
                                    <span t-esc="doc.name"/>
                                </h1>
                            </div>

                            <div style="float:right; width:30%; text-align:right; font-size:12px;">
                                <strong>Date:</strong><br/>
                                <span t-field="doc.create_date" t-options='{"format": "dd-MM-yyyy"}'/>
                            </div>

                            <div style="clear:both;"></div>
                        </div>

                    </div>
                    <div class="row" style="margin-bottom:15px;">
                        <div class="col-4">
                            <div style="border:1px">
                                <div style="background:#e6e6e6; color:#000; padding:6px; font-size:13px;">
                                    <strong>Shipper</strong>
                                </div>
                                <div style="padding:8px; font-size:12px; line-height:18px;">
                                    <strong t-field="doc.shipper_id.name"/><br/>
                                    <span t-field="doc.shipper_id.street"/><br/>
                                    <span t-field="doc.shipper_id.city"/>
                                    <span t-field="doc.shipper_id.state_id.name"/><br/>
                                    <span t-field="doc.shipper_id.country_id.name"/><br/>
                                    <strong>Phone:</strong> <span t-field="doc.shipper_id.phone"/><br/>
                                    <strong>Email:</strong> <span t-field="doc.shipper_id.email"/>
                                </div>
                            </div>
                        </div>

                        <div class="col-4">
                            <div style="border:1px">
                                <div style="background:#e6e6e6; color:#000; padding:6px; font-size:13px;">
                                    <strong>Consignee</strong>
                                </div>
                                <div style="padding:8px; font-size:12px; line-height:18px;">
                                    <strong t-field="doc.consignee_id.name"/><br/>
                                    <span t-field="doc.consignee_id.street"/><br/>
                                    <span t-field="doc.consignee_id.city"/>
                                    <span t-field="doc.consignee_id.state_id.name"/><br/>
                                    <span t-field="doc.consignee_id.country_id.name"/><br/>
                                    <strong>Phone:</strong> <span t-field="doc.consignee_id.phone"/><br/>
                                    <strong>Email:</strong> <span t-field="doc.consignee_id.email"/>
                                </div>
                            </div>
                        </div>

                        <div class="col-4">
                            <div>
                                <div style="background:#e6e6e6; color:#000; padding:6px; font-size:13px;">
                                    <strong>Carrier</strong>
                                </div>
                                <div style="padding:8px; font-size:12px; line-height:18px;">
                                    <strong t-field="doc.carrier_id.name"/><br/>
                                    <strong>Driver:</strong> <span t-esc="doc.driver_name"/><br/>
                                    <strong>Truck No:</strong> <span t-esc="doc.vehicle_number"/><br/>
                                    <strong>Driver Phone:</strong> <span t-esc="doc.driver_phone"/><br/>
                                    <strong>Driver Email:</strong> <span t-esc="doc.driver_email"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row" style="margin-bottom:15px;">
                        <div class="col-6">
                            <div style="border:1px">
                                <div style="background:#e6e6e6; color:#000; padding:6px;">
                                    <strong>Departure Details</strong>
                                </div>
                                <div style="padding:8px; font-size:12px;">
                                    <strong>Load Port:</strong> <span t-esc="doc.loading_port_id.name"/><br/>
                                    <strong>ETD:</strong> <span t-esc="doc.etd"/><br/>
                                    <strong>Gross Weight:</strong> <span t-esc="doc.gross_weight"/>
                                </div>
                            </div>
                        </div>

                        <div class="col-6">
                            <div style="border:1px ">
                                <div style="background:#e6e6e6; color:#000; padding:6px;">
                                    <strong>Arrival Details</strong>
                                </div>
                                <div style="padding:8px; font-size:12px;">
                                    <strong>Discharge Port:</strong> <span t-esc="doc.discharging_port_id.name"/><br/>
                                    <strong>ETA:</strong> <span t-esc="doc.eta"/><br/>
                                    <strong>Net Weight:</strong> <span t-esc="doc.net_weight"/>
                                </div>
                            </div>
                        </div>
                    </div>



                    <table style="width:100%; border-collapse:collapse; margin-bottom:15px;">
                        <thead>
                            <tr style="background:#e6e6e6;">
                                <th style="padding:6px; border:1px solid #000;">Container</th>
                                <th style="padding:6px; border:1px solid #000;">Number</th>
                                <th style="padding:6px; border:1px solid #000;">Vessel</th>
                                <th style="padding:6px; border:1px solid #000;">Packing</th>
                                <th style="padding:6px; border:1px solid #000;">Goods</th>
                                <th style="padding:6px; border:1px solid #000;">Weight</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="doc.order_ids" t-as="line">
                                <tr>
                                    <td style="padding:5px; border:1px solid #000;"><span t-esc="line.container_id.name"/></td>
                                    <td style="padding:5px; border:1px solid #000;"><span t-esc="line.container_number"/></td>
                                    <td style="padding:5px; border:1px solid #000;"><span t-esc="line.vessel"/></td>
                                    <td style="padding:5px; border:1px solid #000;"><span t-esc="line.packing_no"/></td>
                                    <td style="padding:5px; border:1px solid #000;"><span t-esc="line.product_id.name"/></td>
                                    <td style="padding:5px; border:1px solid #000;"><span t-esc="line.weight"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <t t-set="total_amount" t-value="sum(doc.service_ids.mapped('total_sale'))"/>

                    <table style="width:100%; border-collapse:collapse; margin-bottom:10px;">
                        <thead>
                            <tr style="background:#e6e6e6;">
                                <th style="padding:6px; border:1px solid #000;">Category</th>
                                <th style="padding:6px; border:1px solid #000;">Service</th>
                                <th style="padding:6px; border:1px solid #000;">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="doc.service_ids" t-as="srv">
                                <tr>
                                    <td style="padding:5px; border:1px solid #000;"><span t-esc="srv.category_id.name"/></td>
                                    <td style="padding:5px; border:1px solid #000;"><span t-esc="srv.service_id.name"/></td>
                                    <td style="padding:5px; border:1px solid #000; text-align:right;">
                                        <span t-esc="srv.total_sale"/>
                                    </td>
                                </tr>
                            </t>

                            <tr style="background:#eee;">
                                <td colspan="2" style="padding:6px; text-align:right; border:1px solid #000;">
                                    <strong>Total</strong>
                                </td>
                                <td style="padding:6px; border:1px solid #000; text-align:right;">
                                    <strong><span t-esc="total_amount"/></strong>
                                </td>
                            </tr>
                        </tbody>
                    </table>

                    <div style="border:1px solid #000; padding:8px; font-size:12px;">
                        <strong>Amount in Words:</strong><br/>
                        <span t-esc="doc.currency_id.amount_to_text(total_amount)"/>
                    </div>

                    <div style="width:100%; margin-top:40px;">

                        <div style="float:right; width:250px; text-align:center;">
                            <div style="height:60px;"></div>
                            <div style="border-top:1px solid #000; margin-top:5px;"></div>
                            <div style="font-size:12px; margin-top:5px;">
                                <strong>Authorised Signatory</strong>
                            </div>
                            <div style="font-size:12px;">
                                <span t-field="doc.company_id.name"/>
                            </div>
                        </div>

                        <div style="clear:both;"></div>
                    </div>
                    

                </t>
            </t>
        </t>
    </template>
</odoo>

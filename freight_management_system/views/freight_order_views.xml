<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--Freight order tree view-->
    <record id="freight_order_view_tree" model="ir.ui.view">
        <field name="name">freight.order.view.tree</field>
        <field name="model">freight.order</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="type"/>
                <field name="transport_type"/>
                <field name="loading_port_id"/>
                <field name="discharging_port_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>
    <!--Freight order form view-->
    <record id="freight_order_view_form" model="ir.ui.view">
        <field name="name">freight.order.view.form</field>
        <field name="model">freight.order</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_create_custom_clearance"
                            string="Create Custom Clearance" type="object"
                            class="oe_highlight"
                            data-hotkey="w"
                            invisible="1"/>
                    <button name="action_submit" string="Submit"
                            type="object" class="oe_highlight"
                            data-hotkey="w" invisible="state != 'draft'"/>
                    <button name="action_confirm" string="Confirm"
                            type="object" class="oe_highlight"
                            data-hotkey="w" invisible="state != 'submit'"/>
                    <!-- <button name="action_create_invoice" string="Invoice"
                            type="object" class="oe_highlight"
                            data-hotkey="w" invisible="state != 'confirm'"/>-->
                    <button name="action_track_order" string="Tracking"
                            type="object" class="oe_highlight"
                            invisible="state not in ('confirm', 'invoice')"
                            data-hotkey="w"/> 
                    <button name="action_done" string="Done" type="object"
                            class="oe_highlight"
                            invisible="state not in ('confirm', 'invoice')"
                            data-hotkey="w"/>
                    <button name="action_cancel" string="Cancel"
                            type="object"
                            invisible="state not in ('draft', 'submit', 'confirm', 'invoice')"
                            data-hotkey="w"/>
                    <button name="action_reset_to_draft" string="Reset to Draft"
                            type="object"
                            invisible="state not in ('submit', 'confirm')"
                            data-hotkey="w"/>

                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submit,confirm"
                           readonly="1"/>
                </header>
                <sheet>
                    <!-- <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object"
                                name="get_custom_clearance"
                                icon="fa-id-card-o">
                            <field string="Clearance" name="clearance_count"
                                   widget="statinfo"/>
                        </button>
                        <button class="oe_stat_button" type="object"
                                name="get_invoice"
                                icon="fa-pencil-square-o">
                            <field string="Invoice" name="invoice_count"
                                   widget="statinfo"/>
                        </button>
                    </div> -->
                    <div class="oe_title">
                        <h1 class="mt0">
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="shipper_id" readonly="state in 'done'"/>
                            <field name="consignee_id" readonly="state in 'done'"/>
                            <field name="order_date" readonly="state in 'done'"/>
                            <field name="company_id" invisible="1" readonly="state in 'done'"/>
                            <field name="loading_port_id"/>
                            <field name="agent_id" readonly="state in 'done'"/>
                            <field name="incoterm_id" readonly="state in 'done'"/>
                        </group>
                        <group>
                            <field name="clearance" invisible="1" readonly="state in 'done'"/>
                            <field name="type" readonly="state in 'done'"/>
                            <field name="transport_type" readonly="state in 'done'"/>
                            <field name="discharging_port_id"/>
                            <field name="expected_date" readonly="state in 'done'"/>
                        </group>
                    </group>

                    <!-- <group>
                        <group>
                            <field name="incoterm_id" readonly="state in 'done'"/>
                        </group>
                        <group>
                            <field name="certificate_of_analysis" readonly="state in 'done'"/>
                        </group>
                    </group> -->
                    <!-- <group>
                        <group>
                            <field name="bill_of_loading" readonly="state in 'done'"/>
                        </group>
                        <group>
                            <field name="commercial_invoice" readonly="state in 'done'"/>
                        </group>
                    </group> -->
                    <notebook>
                        <page string="Order">
                            <field name="order_ids" readonly="state in 'done'">
                                <list string="Order Lines"
                                      editable="bottom">
                                    <field name="container_id"/>
                                    <!-- <field name="vessel_id"/> -->
                                    <field name="vessel"/>
                                    <field name="packing_no"/>
                                    <!-- <field name="packing_list_ids" widget="many2many_tags" string="No.of packet list"/> -->
                                    <field name="product_id"/>
                                    <!-- <field name="billing_type"/> -->
                                    <!-- <field name="pricing_id"/> -->
                                    <!-- <field name="volume"
                                           invisible="billing_type != 'volume'" optional="hide"/> -->
                                    <field name="weight"/>
                                    <!-- <field name="price"/>
                                    <field name="total_price"/> -->
                                </list>
                            </field>
                            <!-- <group class="oe_subtotal_footer oe_right"
                                   colspan="2">
                                <div class="oe_inline o_td_label">
                                    <label for="total_volume"/>
                                </div>
                                <field name="total_volume" nolabel="1"/>
                                <div class="oe_inline o_td_label">
                                    <label for="total_weight"/>
                                </div>
                                <field name="total_weight" nolabel="1"/>
                                <div class="oe_inline o_td_label">
                                    <label for="total_order_price"/>
                                </div>
                                <field name="total_order_price"
                                       nolabel="1"/>
                            </group> -->
                        </page>
                        <page string="Routes">
                            <field name="route_ids" readonly="state in 'done'">
                                <list string="Routes" editable="bottom">
                                    <field name="routes_id"/>
                                    <field name="origin_location"/>
                                    <field name="transport_type"/>
                                    <field name="destination_location"/>
                                    <field name="source_loc_id"/>
                                    <field name="destination_loc_id"/>
                                    <!-- <field name="sale"/> -->
                                </list>
                            </field>
                            <!-- <group class="oe_subtotal_footer oe_right"
                                   colspan="2">
                                <div class="oe_inline o_td_label">
                                    <label for="total_route_sale"/>
                                </div>
                                <field name="total_route_sale" nolabel="1"/>
                            </group> -->
                        </page>
                        <page string="Services">
                            <field name="service_ids" readonly="state in 'done'">
                                <list string="Services" editable="bottom">
                                    <!-- <field name="partner_id" /> -->
                                    <field name="category_id"/>
                                    <field name="service_id" domain="[('category_id', '=', category_id)]"/>
                                    <field name="qty" string="Details" optional="hide"/>
                                    <field name="sale" string="VOL" optional="hide"/>
                                    <field name="company_currency_id" invisible="1"/>
                                    <field name="total_sale" string="Amount" widget="monetary" options="{'currency_field': 'company_currency_id'}"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer oe_right"
                                   colspan="2">
                                <field name="currency_id" invisible="1"/>
                                <div class="oe_inline o_td_label">
                                    <label for="total_service_amount"/>
                                </div>
                                <field name="total_service_amount" widget="monetary" options="{'currency_field': 'currency_id'}"
                                       nolabel="1"/>
                            </group>
                        </page>
                        <page string="Track">
                            <field name="track_ids">
                                <list string="Services" editable="bottom"
                                      create="0">
                                    <field name="source_loc_id"/>
                                    <field name="destination_loc_id"/>
                                    <field name="transport_type"/>
                                    <field name="date"/>
                                    <field name="type"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                 <!-- Chatter -->
                <chatter/>
<!--                    <div class="oe_chatter">-->
<!--                        <field name="message_follower_ids" groups="base.group_user"/>-->
<!--                        <field name="activity_ids"/>-->
<!--                        <field name="message_ids"/>-->
<!--                    </div>-->
            </form>
        </field>
    </record>
    <!--Action for freight order-->
    <record id="freight_order_action" model="ir.actions.act_window">
        <field name="name">Freight Order</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">freight.order</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define a new freight order
            </p>
        </field>
    </record>
    <!--Defined menus-->
    <menuitem id="freight_order_menu_root" name="Freight Management"
              web_icon="freight_management_system,static/description/icon.png"
              sequence="4" action="freight_order_action"/>

    <menuitem id="freight_order_menu_shipping" name="Shipping"
              parent="freight_order_menu_root" sequence="2"
              action="freight_order_action"/>
</odoo>

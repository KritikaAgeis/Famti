<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
<data>
    <!--Tree view for freight Vessels-->
    <record id="freight_vessels_view_tree" model="ir.ui.view">
        <field name="name">freight.vessel.view.tree</field>
        <field name="model">freight.vessel</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    <!--Form view of the freight vessels-->
    <record id="freight_vessels_form_view" model="ir.ui.view">
        <field name="name">freight.vessel.form.view</field>
        <field name="model">freight.vessel</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <!--Search view of the freight vessels-->
    <record id="freight_vessels_view_search" model="ir.ui.view">
        <field name="name">freight.vessel.view.search</field>
        <field name="model">freight.vessel</field>
        <field name="arch" type="xml">
            <search>
                <filter string="Inactive" name="inactive"
                        domain="[('active','=',False)]"/>
            </search>
        </field>
    </record>
    <!--    Action-->
    <record id="freight_vessels_action" model="ir.actions.act_window">
        <field name="name">Freight vessels</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">freight.vessel</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define a new freight vessels
            </p>
        </field>
    </record>

    <menuitem id="menu_freight_vessels" name="Vessels"
              parent="menu_configuration" sequence="2"
              action="freight_vessels_action"/>
</data>
</odoo>
